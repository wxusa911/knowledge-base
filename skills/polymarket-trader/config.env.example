# Polymarket Trader 配置

# 新闻API Token (必需)
OPENNEWS_TOKEN=your-token-here

# Polymarket 私钥 (实盘必需)
POLYMARKET_PRIVATE_KEY=your-private-key

# Polygon RPC URL (实盘必需)
POLYGON_RPC_URL=https://polygon-rpc.com

# 交易配置
INITIAL_CAPITAL=100
TRADE_AMOUNT=10  # 每次10%
FEE=0.02

# 缓存配置 (秒)
CACHE_TTL=300

# 信号阈值
SIGNAL_THRESHOLD=50
MIN_SCORE=60
MIN_LIQUIDITY=5000
